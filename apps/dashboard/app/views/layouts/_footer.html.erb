<footer class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center p-4 gap-3">
  <div>
    <div class="fw-semibold">NTUEE Core HPC Portal</div>
    <div class="text-muted small">Department of Electrical Engineering, National Taiwan University</div>
  </div>
  <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-3">
    <div class="text-muted small" id="ood_version">OnDemand version: <%= Configuration.ood_version %> · <a href="https://openondemand.org/licensing">Software License Notice</a></div>
    <div class="me-2">
      <%= link_to "https://openondemand.org" do %>
        <%=
          image_tag(
            "OpenOnDemand_powered_by_RGB.svg",
            class: "footer-logo",
            alt: "Powered by Open OnDemand",
            height: "34px",
          )
        %>
      <% end %>
    </div>
  </div>
</footer>
